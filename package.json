{
  "scripts": {
    "dev": "vite",
    "build": "npm run validate:data && vite build",
    "preview": "vite preview",
    "validate:data": "node --import tsx scripts/validate-events.ts",
    "status:update": "node --import tsx scripts/update-statuses.ts",
    "typecheck": "tsc --noEmit && vue-tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.0.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "jsdom": "^29.0.1",
    "json-schema-to-ts": "^3.1.1",
    "jsonc-parser": "^3.3.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  },
  "dependencies": {
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  }
}
